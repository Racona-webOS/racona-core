{
	"name": "create-elyos-plugin",
	"version": "0.1.0",
	"description": "CLI tool to scaffold ElyOS plugin projects",
	"type": "module",
	"bin": {
		"create-elyos-plugin": "./dist/cli.js"
	},
	"main": "./dist/cli.js",
	"files": [
		"dist",
		"templates"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"keywords": [
		"elyos",
		"webos",
		"plugin",
		"cli",
		"scaffold",
		"generator"
	],
	"author": "ElyOS Team",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/elyos/core",
		"directory": "packages/create-elyos-plugin"
	},
	"dependencies": {
		"commander": "^13.0.0",
		"prompts": "^2.4.2",
		"picocolors": "^1.1.0"
	},
	"devDependencies": {
		"@types/node": "^25.3.5",
		"@types/prompts": "^2.4.9",
		"typescript": "^5.7.0",
		"vitest": "^3.1.0"
	}
}
