{
	"name": "@racona/sdk",
	"version": "0.3.0",
	"description": "Racona SDK — runtime and development SDK for Racona plugin development",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./dev": {
			"types": "./dist/dev/index.d.ts",
			"import": "./dist/dev/index.js"
		},
		"./dev/components/SimpleDataTable.svelte": {
			"svelte": "./src/dev/components/SimpleDataTable.svelte",
			"default": "./src/dev/components/SimpleDataTable.svelte"
		},
		"./dev/components/SimpleRowActions.svelte": {
			"svelte": "./src/dev/components/SimpleRowActions.svelte",
			"default": "./src/dev/components/SimpleRowActions.svelte"
		},
		"./types": {
			"types": "./dist/types/index.d.ts"
		}
	},
	"files": [
		"dist",
		"src/dev/components"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json && tsc -p tsconfig.dev.json",
		"build:runtime": "tsc -p tsconfig.json",
		"build:dev": "tsc -p tsconfig.dev.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.dev.json",
		"clean": "rm -rf dist",
		"prepublishOnly": "bun run clean && bun run build",
		"jsr:publish": "bunx jsr publish",
		"jsr:publish:dry": "bunx jsr publish --dry-run"
	},
	"keywords": [
		"racona",
		"sdk",
		"plugin",
		"typescript"
	],
	"author": "Racona Team",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/racona/racona-core",
		"directory": "packages/sdk"
	},
	"homepage": "https://racona.hu",
	"devDependencies": {
		"typescript": "^5.7.0",
		"vitest": "^3.1.0"
	}
}
