{
	"name": "@racona/cli",
	"version": "0.3.0",
	"description": "CLI tool to scaffold Racona app projects",
	"type": "module",
	"bin": {
		"create-racona-app": "./dist/cli.js"
	},
	"main": "./dist/cli.js",
	"files": [
		"dist",
		"templates"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"keywords": [
		"racona",
		"plugin",
		"cli",
		"scaffold",
		"generator"
	],
	"author": "Racona Team",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/racona/racona-core",
		"directory": "packages/cli"
	},
	"homepage": "https://racona.hu",
	"dependencies": {
		"commander": "^13.0.0",
		"prompts": "^2.4.2",
		"picocolors": "^1.1.0"
	},
	"devDependencies": {
		"@types/node": "^25.3.5",
		"@types/prompts": "^2.4.9",
		"fast-check": "^4.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.1.0"
	}
}
