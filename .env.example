# =============================================================================
# Racona Core — Environment Variables / Környezeti változók
# =============================================================================
# Copy this file to .env and customize the values as needed.
# Másold ezt a fájlt .env névvel és szükség szerint módosítsd az értékeket.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration / Szerver konfiguráció
# -----------------------------------------------------------------------------

NODE_ENV=production
BODY_SIZE_LIMIT=10485760
RACONA_PORT=3000
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database Configuration / Adatbázis konfiguráció
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://racona:racona123@postgres:5432/racona
POSTGRES_USER=racona
POSTGRES_PASSWORD=racona123
POSTGRES_HOST=postgres
POSTGRES_DB=racona
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Application Branding / Alkalmazás megjelenés
# -----------------------------------------------------------------------------

APP_NAME=Racona
APP_LOGO_URL=/logos/logo-small.png
EMAIL_USE_LOGO=true

# -----------------------------------------------------------------------------
# Authentication / Hitelesítés (better-auth)
# -----------------------------------------------------------------------------

# IMPORTANT: Generate a secure secret with: openssl rand -base64 32
# FONTOS: Generálj biztonságos titkos kulcsot: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
BETTER_AUTH_URL=http://localhost:3000
ORIGIN=http://localhost:3000

# DEPRECATED: These settings are now managed in the database via Settings > Authentication
# Use the admin panel to configure registration and social login options.
# ---
# ELAVULT: Ezek a beállítások mostantól az adatbázisban vannak kezelve a Beállítások > Hitelesítés menüpontban.
# Használd az admin panelt a regisztráció és social login opciók konfigurálásához.
# REGISTRATION_ENABLED=true
# SOCIAL_LOGIN_ENABLED=false

# Google OAuth credentials (configure in Settings > Authentication if social login is enabled)
# Google OAuth hitelesítő adatok (konfiguráld a Beállítások > Hitelesítés menüpontban, ha a social login engedélyezve van)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Encryption / Titkosítás
# -----------------------------------------------------------------------------

# IMPORTANT: Generate a secure 32-byte encryption key with: openssl rand -hex 32
# FONTOS: Generálj biztonságos 32 bájtos titkosítási kulcsot: openssl rand -hex 32
# Used for encrypting sensitive data like AI agent API keys
# AI agent API kulcsok és más érzékeny adatok titkosításához használatos
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# -----------------------------------------------------------------------------
# Initial Admin User / Kezdeti adminisztrátor felhasználó
# -----------------------------------------------------------------------------

ADMIN_USER_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Email Configuration / Email konfiguráció
# -----------------------------------------------------------------------------

EMAIL_PROVIDER=smtp
EMAIL_TEST_MODE=false
EMAIL_LOG_LEVEL=info
EMAIL_OTP_EXPIRES_IN=10

# SMTP Configuration (default values for testing)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-username
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Racona
SMTP_REPLY_TO=support@example.com

# Resend (uncomment if using Resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# RESEND_VERIFIED_EMAIL=
# RESEND_WEBHOOK_SECRET=

# SendGrid (uncomment if using SendGrid)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# AWS SES (uncomment if using AWS SES)
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Email Verification / Email megerősítés
# -----------------------------------------------------------------------------

REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_EXPIRES_IN=86400
AUTO_SIGNIN_AFTER_VERIFICATION=true
VERIFICATION_FEATURE_ENABLED=true
VERIFICATION_NEW_USERS_ONLY=false
VERIFICATION_ROLLOUT_PERCENTAGE=100
VERIFICATION_ROLLOUT_START_DATE=2024-01-01T00:00:00Z

# -----------------------------------------------------------------------------
# Internationalization / Többnyelvűség (i18n)
# -----------------------------------------------------------------------------

SUPPORTED_LOCALES=hu,en
DEFAULT_LOCALE=hu

# -----------------------------------------------------------------------------
# Logging / Naplózás
# -----------------------------------------------------------------------------

LOG_TARGETS=console
LOG_LEVEL=info
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# Development Mode / Fejlesztői mód
# -----------------------------------------------------------------------------

# Enable dev plugin loading from localhost.
# WARNING: Only enable in development environments!
# ---
# Fejlesztői plugin betöltés engedélyezése localhostról.
# FIGYELEM: Csak fejlesztői környezetben engedélyezd!
DEV_MODE=false

# -----------------------------------------------------------------------------
# Demo Mode / Demo mód
# -----------------------------------------------------------------------------

# Enable demo mode — the app indicates to users that they are in a demo environment.
# The actual database reset happens at infrastructure level: a separate Docker Compose
# configuration on the VPS resets the database to its initial state daily.
# This flag alone does not restrict data modifications.
# ---
# Demo mód engedélyezése — az alkalmazás jelzi a felhasználóknak, hogy demo környezetben futnak.
# A tényleges adatbázis-reset infrastruktúra szinten történik: a VPS-en egy külön
# Docker Compose konfiguráció naponta visszaállítja az adatbázist az alapállapotra.
# Ez a flag önmagában nem korlátozza az adatmódosításokat.
DEMO_MODE=false

# Hour (UTC, 0–23) when the demo database resets daily.
# Az óra (UTC, 0–23), amikor a demo adatbázis naponta visszaáll.
DEMO_RESET_HOUR=4

# Comma-separated uploads subdirectories to keep during demo reset.
# Vesszővel elválasztott feltöltési alkönyvtárak, amelyek megmaradnak a demo reset során.
DEMO_RESET_UPLOADS_KEEP=backgrounds/shared

# -----------------------------------------------------------------------------
# Public Site / Publikus oldal
# -----------------------------------------------------------------------------

PUBLIC_SITE_ENABLED=true

# -----------------------------------------------------------------------------
# Activity Log / Aktivitás napló
# -----------------------------------------------------------------------------

# Ha false, az activityLogService.log() hívások azonnal visszatérnek, semmi sem kerül az adatbázisba
ACTIVITY_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Plugin System / Plugin rendszer
# -----------------------------------------------------------------------------

PLUGIN_PACKAGE_EXTENSION=raconapkg
PLUGIN_MAX_SIZE=10485760
PLUGIN_STORAGE_DIR=/var/webos/plugins
PLUGIN_TEMP_DIR=/tmp/webos-plugins

# -----------------------------------------------------------------------------
# Error Monitoring / Hibafigyelés
# -----------------------------------------------------------------------------

# Hibafigyelés be/kikapcsolása. Ha false, a DSN beállítástól függetlenül ki van kapcsolva.
# PUBLIC_ prefix szükséges, hogy a kliens oldal is olvashassa.
PUBLIC_MONITORING_ENABLED=false

# Szerver oldali DSN — Sentry, GlitchTip (self-hosted vagy cloud), vagy bármely
# Sentry-kompatibilis provider DSN-je megadható.
# Pl.: https://abc123@app.glitchtip.com/1  vagy  https://abc123@sentry.io/1
# ERROR_TRACKING_DSN=

# Kliens oldali DSN — publikus, a böngészőben is elérhető, ugyanaz a DSN használható.
# PUBLIC_ERROR_TRACKING_DSN=
