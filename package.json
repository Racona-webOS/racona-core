{
	"name": "elyos",
	"version": "0.1.3",
	"private": false,
	"license": "MIT",
	"workspaces": [
		"packages/*",
		"apps/*",
		"examples/plugins/*"
	],
	"scripts": {
		"app:dev": "bun --elide-lines=0 --filter @elyos/core dev",
		"app:dev:varlock": "bun --elide-lines=0 --filter @elyos/core dev:varlock",
		"app:build": "bun --filter @elyos/core build",
		"app:check": "bun --elide-lines=0 --filter @elyos/core check",
		"db:generate": "bun --filter @elyos/database db:generate",
		"db:migrate": "bun --filter @elyos/database db:migrate",
		"db:studio": "bun --filter @elyos/database db:studio",
		"db:seed": "bun --filter @elyos/database db:seed",
		"db:init": "bun --elide-lines=0 --filter @elyos/database db:init",
		"db:reset": "bun --filter @elyos/database db:reset",
		"docker:up": "docker compose -f docker/docker-compose.yml --env-file .env up -d --build",
		"docker:up:ghcr": "docker compose -f docker/docker-compose.ghcr.yml --env-file .env up -d",
		"docker:rebuild": "docker compose -f docker/docker-compose.yml --env-file .env build --no-cache && docker compose -f docker/docker-compose.yml --env-file .env up -d",
		"docker:db": "docker compose -f docker/docker-compose.yml --env-file .env up postgres -d",
		"docker:down": "docker compose -f docker/docker-compose.yml down",
		"docker:down:ghcr": "docker compose -f docker/docker-compose.ghcr.yml down",
		"docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
		"docker:logs:ghcr": "docker compose -f docker/docker-compose.ghcr.yml logs -f",
		"docker:build": "docker build -f docker/Dockerfile -t elyos/core:latest .",
		"docker:build:amd64": "docker build -f docker/Dockerfile --platform linux/amd64 -t elyos/core:latest-amd64 -t elyos/core:0.1.0-amd64 .",
		"docker:build:arm64": "docker build -f docker/Dockerfile --platform linux/arm64 -t elyos/core:latest-arm64 -t elyos/core:0.1.0-arm64 .",
		"docker:save:amd64": "docker save -o docker/elyos-core.tar elyos/core:latest-amd64",
		"docker:save:arm64": "docker save -o docker/elyos-core.tar elyos/core:latest-arm64",
		"docker:save:zstd:amd64": "docker save elyos/core:latest-amd64 | zstd -9 > ./docker/elyos-core-amd64.tar.zst",
		"docker:save:zstd:arm64": "docker save elyos/core:latest-arm64 | zstd -9 > ./docker/elyos-core-arm64.tar.zst"
	},
	"devDependencies": {
		"@types/dompurify": "^3.2.0",
		"prettier": "~3.8.1",
		"prettier-plugin-css-order": "^2.2.0",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.2"
	}
}
