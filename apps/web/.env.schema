# Racona Core — Varlock Env Schema
# Ez a fájl az egyetlen igazságforrás az összes env változó típusához és
# validációs szabályaihoz. A Varlock @env-spec formátumát használja.
# A típusgenerálás automatikusan fut: @generateTypes alapján a Varlock
# létrehozza az src/env.d.ts TypeScript típusfájlt — ne szerkeszd kézzel!
# Alapértelmezett típus: string, nem kell kiírni
#
# @import(../../.env.local, allowMissing=true)
# @currentEnv=$NODE_ENV
# @defaultRequired=false @defaultSensitive=false
# @generateTypes(lang=ts, path=src/env.d.ts)
# ---

# Bootstrap Credentials / Bootstrap hitelesítő adatok

INFISICAL_CLIENT_ID=

# @sensitive @required=not(isEmpty($INFISICAL_CLIENT_ID))
INFISICAL_CLIENT_SECRET=

# Server Configuration / Szerver konfiguráció

# @required @type=enum(development,production,test)
NODE_ENV=development

# @type=number
BODY_SIZE_LIMIT=10485760

# @type=port
RACONA_PORT=3000

# @required @type=url
ORIGIN=

# @type=url
APP_URL=fallback(ref('ORIGIN'),'')

# Database Configuration / Adatbázis konfiguráció

# @required @sensitive
POSTGRES_USER=

# @required @sensitive
POSTGRES_PASSWORD=

# @required
POSTGRES_HOST=localhost

# @required @sensitive
POSTGRES_DB=

# @required @type=port @sensitive
POSTGRES_PORT=5432

# @required @type=url @sensitive
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Application Branding / Alkalmazás megjelenés

APP_NAME=Racona

APP_LOGO_URL=/logos/logo-small.png

EMAIL_USE_LOGO=true

# Authentication / Hitelesítés (better-auth)

# @required @type=string @sensitive
BETTER_AUTH_SECRET=

# @required @type=url
BETTER_AUTH_URL=

REGISTRATION_ENABLED=true

SOCIAL_LOGIN_ENABLED=true

# @required=eq($SOCIAL_LOGIN_ENABLED, true)
GOOGLE_CLIENT_ID=

# @sensitive @required=eq($SOCIAL_LOGIN_ENABLED, true)
GOOGLE_CLIENT_SECRET=

# Email Configuration / Email konfiguráció

# @type=enum(smtp,resend,sendgrid,ses)
EMAIL_PROVIDER=smtp

# @required=eq($EMAIL_PROVIDER, smtp)
SMTP_HOST=

# @type=port @required=eq($EMAIL_PROVIDER, smtp)
SMTP_PORT=587

SMTP_SECURE=false

# @type=email(normalize=true) @required=eq($EMAIL_PROVIDER, smtp)
SMTP_USERNAME=

# @sensitive @required=eq($EMAIL_PROVIDER, smtp)
SMTP_PASSWORD=

SMTP_FROM_NAME=fallback(ref('APP_NAME'),'Racona')

# @type=email(normalize=true) @required=eq($EMAIL_PROVIDER, smtp)
SMTP_FROM_EMAIL=fallback(ref("SMTP_USERNAME"),'')

# @type=email(normalize=true)
SMTP_REPLY_TO=fallback(ref("SMTP_USERNAME"),'')

# @sensitive @required=eq($EMAIL_PROVIDER, resend)
RESEND_API_KEY=

# @type=email(normalize=true) @required=eq($EMAIL_PROVIDER, resend)
RESEND_FROM_EMAIL=onboarding@resend.dev

# @type=email(normalize=true) @required=eq($EMAIL_PROVIDER, resend)
RESEND_VERIFIED_EMAIL=

# @sensitive @required=eq($EMAIL_PROVIDER, resend)
RESEND_WEBHOOK_SECRET=

# @type=string @sensitive @required=eq($EMAIL_PROVIDER, sendgrid)
SENDGRID_API_KEY=

# @type=email(normalize=true) @required=eq($EMAIL_PROVIDER, sendgrid)
SENDGRID_FROM_EMAIL=

# @required=eq($EMAIL_PROVIDER, ses)
AWS_REGION=

# @required=eq($EMAIL_PROVIDER, ses)
AWS_ACCESS_KEY_ID=

# @required=eq($EMAIL_PROVIDER, ses)
AWS_SECRET_ACCESS_KEY=

EMAIL_TEST_MODE=false

# @type=enum(debug,info,warn,error)
EMAIL_LOG_LEVEL=debug

# @type=number(min=1,max=20)
EMAIL_OTP_EXPIRES_IN=10

# Email Verification / Email megerősítés

REQUIRE_EMAIL_VERIFICATION=true

# @type=number(min=1,max=604800)
EMAIL_VERIFICATION_EXPIRES_IN=86400

AUTO_SIGNIN_AFTER_VERIFICATION=false

VERIFICATION_FEATURE_ENABLED=true

VERIFICATION_NEW_USERS_ONLY=false

# @type=number(min=0,max=100)
VERIFICATION_ROLLOUT_PERCENTAGE=100

# Internationalization / Többnyelvűség (i18n)

SUPPORTED_LOCALES=hu,en

# @required @type=enum(hu,en)
DEFAULT_LOCALE=hu

# Logging / Naplózás

LOG_TARGETS=console

# @type=enum(debug,info,warn,error,fatal)
LOG_LEVEL=debug

LOG_DIR=./logs

# Development mode

DEV_MODE=false

# Demo Mode

DEMO_MODE=false

# @type=number(min=0,max=23)
DEMO_RESET_HOUR=4

DEMO_RESET_UPLOADS_KEEP=

# Public Site / Publikus oldal

PUBLIC_SITE_ENABLED=true

# Activity Log / Aktivitás napló

# Ha false, az activityLogService.log() hívások azonnal visszatérnek, semmi sem kerül az adatbázisba
ACTIVITY_LOG_ENABLED=true

# Plugin System / Plugin rendszer

PLUGIN_PACKAGE_EXTENSION=raconapkg

# @type=number(min=1,max=104857600)
PLUGIN_MAX_SIZE=10485760

PLUGIN_STORAGE_DIR=/var/webos/plugins

PLUGIN_TEMP_DIR=/tmp/webos-plugins

# @type=email(normalize=true) @required
ADMIN_USER_EMAIL=

# AI Model Defaults / AI Model alapértékek

AI_GEMINI_DEFAULT_MODEL=

AI_GROQ_DEFAULT_MODEL=

AI_OPENAI_DEFAULT_MODEL=

AI_ANTHROPIC_DEFAULT_MODEL=

AI_HUGGINGFACE_DEFAULT_MODEL=

AI_CUSTOM_DEFAULT_MODEL=
