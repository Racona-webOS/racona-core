{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@elyos/core",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "dotenv -e ../../.env.local -- vite dev",
		"dev:varlock": "varlock run -- vite dev",
		"build": "dotenv -e ../../.env -- vite build",
		"preview": "node server.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"package:update": "bun update -i",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:pbt": "vitest --run --testNamePattern='Property'"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.4.0",
		"@fontsource-variable/montserrat": "^5.2.8",
		"@fontsource-variable/quicksand": "^5.2.10",
		"@internationalized/date": "^3.10.1",
		"@lucide/svelte": "^1.7.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/adm-zip": "^0.5.8",
		"@types/node": "^25.5.2",
		"@types/nodemailer": "^7.0.9",
		"@types/pg": "^8.20.0",
		"@vitest/coverage-v8": "^4.1.2",
		"better-auth": "^1.5.6",
		"bits-ui": "^2.16.5",
		"clsx": "^2.1.1",
		"cross-env": "^10.1.0",
		"dotenv": "^17.4.0",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"drizzle-valibot": "^0.4.2",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jsdoc": "^62.9.0",
		"eslint-plugin-svelte": "^3.17.0",
		"fast-check": "^4.6.0",
		"globals": "^17.2.0",
		"html-to-image": "^1.11.13",
		"jsdom": "^29.0.1",
		"lucide-svelte": "^1.0.1",
		"lz-string": "^1.5.0",
		"mode-watcher": "^1.1.0",
		"nodemailer": "^8.0.4",
		"pg": "^8.17.2",
		"phosphor-svelte": "^3.1.0",
		"prettier": "~3.8.1",
		"prettier-plugin-css-order": "^2.2.0",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"resend": "^6.10.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-moveable": "^0.45.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tailwindcss-animate": "^1.0.7",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"valibot": "^1.3.1",
		"vaul-svelte": "^0.3.2",
		"vite": "^8.0.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.5.6",
		"@elyos/database": "workspace:*",
		"@elyos/sdk": "workspace:*",
		"@tanstack/table-core": "^8.21.3",
		"@types/dompurify": "^3.2.0",
		"@types/sharp": "^0.32.0",
		"@varlock/infisical-plugin": "^0.0.6",
		"@varlock/vite-integration": "^0.2.9",
		"adm-zip": "^0.5.17",
		"express": "^5.2.1",
		"file-type": "^22.0.0",
		"isomorphic-dompurify": "^3.7.1",
		"sharp": "^0.34.5",
		"socket.io": "^4.7.2",
		"socket.io-client": "^4.7.2",
		"svelte-maplibre-gl": "^1.0.3",
		"varlock": "^0.7.1"
	}
}
